# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=generate-a-strong-50-plus-character-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
USE_X_FORWARDED_PROTO=True
SITE_URL=http://127.0.0.1:8000

# ─── Database (production PostgreSQL) ─────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=paraguashopping
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ─── Store ────────────────────────────────────────────────────────────────────
STORE_PHONE=5511999999999
STORE_INSTAGRAM=essencekimportados
STORE_EMAIL=contato@essencekimportados.com.br
STORE_CEP_ORIGEM=01310100

# ─── Exchange rate / Dollar panel ─────────────────────────────────────────────
EXCHANGE_RATE_API_URL=https://economia.awesomeapi.com.br/json/last/USD-BRL
EXCHANGE_RATE_CACHE_SECONDS=3600
EXCHANGE_RATE_DEFAULT_USD_BRL=5.50

# ─── Encryption (AES via Fernet — REQUIRED in production) ────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ─── GTIN / Barcode lookup (optional) ─────────────────────────────────────────
COSMOS_API_TOKEN=

# ─── Payment Gateway (Mercado Pago example) ───────────────────────────────────
PAYMENT_GATEWAY=mercadopago
PAYMENT_SANDBOX=True
MP_ACCESS_TOKEN=your-access-token-here
MP_PUBLIC_KEY=your-public-key-here
MP_WEBHOOK_SECRET=your-webhook-secret
MP_USE_SANDBOX_LINK=True
MP_MAX_INSTALLMENTS=12

# ─── Shipping (Melhor Envio example) ─────────────────────────────────────────
MELHORENVIO_TOKEN=your-melhorenvio-token
MELHORENVIO_ENV=sandbox

# ─── Email (optional) ─────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
