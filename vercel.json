{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "env": {
    "DJANGO_SETTINGS_MODULE": "paraguashopping.settings.vercel"
  },
  "functions": {
    "paraguashopping/wsgi.py": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/media/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, s-maxage=31536000, immutable" }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, s-maxage=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/cron/update-exchange-rate/",
      "schedule": "0 9 * * *"
    }
  ]
}
